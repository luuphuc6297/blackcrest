# ── Database (Postgres 17) ──────────────────────────────────────────────────
# Local dev via docker-compose: postgres on 127.0.0.1:5432
DATABASE_URL="postgresql://blackcrest:blackcrest@127.0.0.1:5432/blackcrest?schema=public"

# ── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# Trust the host in dev / behind nginx in prod
AUTH_TRUST_HOST="true"

# ── Storage (PDF) ───────────────────────────────────────────────────────────
# "filesystem" (default) or "s3" (SeaweedFS). Filesystem volume path:
STORAGE_DRIVER="filesystem"
STORAGE_ROOT="./storage"

# ── Feature flags (env-driven, default OFF) ─────────────────────────────────
# Per-user PDF watermark on view/download. OFF for now; set "true" to enable.
WATERMARK_ENABLED="false"

# ── Storage driver ──────────────────────────────────────────────────────────
# "filesystem" (default, STORAGE_ROOT) or "supabase"/"s3" (S3-compatible object
# store — required on serverless/Vercel where there is no persistent disk).
STORAGE_DRIVER="filesystem"
STORAGE_ROOT="./storage"                       # filesystem driver only
# S3-compatible object store (AWS S3 / Supabase Storage / Cloudflare R2 / MinIO).
S3_BUCKET="blackcrest-reports"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Leave S3_ENDPOINT EMPTY for AWS S3 (SDK uses the region default). For Supabase
# set "https://<ref>.supabase.co/storage/v1/s3"; for R2 the R2 endpoint, etc.
# Path-style auto-enables when S3_ENDPOINT is set; override with S3_FORCE_PATH_STYLE.
S3_ENDPOINT=""
# Watchlist email alerts on report publish (F2). Set "true" to fan out emails when
# a report is published (also requires valid SMTP_*/SendGrid creds). OFF by default
# so a preview/staging deploy with mail creds never sends surprise alerts.
WATCHLIST_EMAILS_ENABLED="false"

# ── Download tokens (one-time, short-lived JWT) ─────────────────────────────
# Separate secret from AUTH_SECRET. openssl rand -base64 32
DOWNLOAD_TOKEN_SECRET="replace-me-too"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Blackcrest"
TZ="Asia/Ho_Chi_Minh"
# Server-only base URL for links inside EMAILS (verification, set-password).
APP_URL="http://localhost:3000"
# Public site origin that search engines & social cards see — drives metadataBase,
# canonical/OG URLs, sitemap.xml and robots.txt. MUST be the real production origin
# (e.g. https://blackcrest.vn); otherwise all of those point at the wrong domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional: Google Search Console "HTML tag" verification token (the content="…"
# value only). When set, emitted as <meta name="google-site-verification">.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ── Email / SMTP (verification emails) ──────────────────────────────────────
# Provider-agnostic SMTP (Nodemailer). If SMTP_HOST is unset, the app logs the
# email + verify link to the server console (dev fallback) instead of sending.
#
# TEST via SendGrid:
#   SMTP_HOST="smtp.sendgrid.net"
#   SMTP_PORT="587"
#   SMTP_USER="apikey"            # the literal word "apikey"
#   SMTP_PASS="SG.xxxxxxxx"       # your SendGrid API key
# PRODUCTION (data-localization): point SMTP_* at an in-territory (VN) server.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Blackcrest <no-reply@blackcrest.vn>"
