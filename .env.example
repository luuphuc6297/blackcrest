# ── Database (Postgres 17) ──────────────────────────────────────────────────
# Local dev via docker-compose: postgres on 127.0.0.1:5432
DATABASE_URL="postgresql://blackcrest:blackcrest@127.0.0.1:5432/blackcrest?schema=public"

# ── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# Trust the host in dev / behind nginx in prod
AUTH_TRUST_HOST="true"

# ── Storage (PDF) ───────────────────────────────────────────────────────────
# "filesystem" (default) or "s3" (SeaweedFS). Filesystem volume path:
STORAGE_DRIVER="filesystem"
STORAGE_ROOT="./storage"

# ── Download tokens (one-time, short-lived JWT) ─────────────────────────────
# Separate secret from AUTH_SECRET. openssl rand -base64 32
DOWNLOAD_TOKEN_SECRET="replace-me-too"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Blackcrest"
TZ="Asia/Ho_Chi_Minh"
