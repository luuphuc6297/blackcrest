// Blackcrest — data model (blueprint §4).
//
// Two INDEPENDENT axes, never mixed:
//   • RBAC        = User.role            → decides ACTIONS (upload/approve/grant).
//   • Entitlement = Entitlement table    → decides WHICH GROUP sees WHICH report,
//                                           granted at group→report OR group→category.
// Staff (SUPER_ADMIN/EDITOR/APPROVER) bypass entitlement EXPLICITLY in code (lib/authz).
// Multilingual content lives in ReportTranslation — one Report = one access entity.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl target is for the node:22-alpine image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // url = pooled (transaction mode) for runtime; directUrl = session pooler for
  // migrations (Prisma + pgbouncer requires the two be split). For local Docker
  // both resolve to the same DSN, so DIRECT_URL is optional there.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  EDITOR
  APPROVER
  CLIENT
}

enum UserStatus {
  INVITED // admin-invited, NO password yet — must accept invite (set password) to activate
  UNVERIFIED // self-registered, email NOT yet confirmed — CANNOT log in, not in approval queue
  PENDING // email confirmed, awaiting manual approval — CANNOT log in
  APPROVED
  SUSPENDED
}

enum ReportStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum AccessLevel {
  PUBLIC // any approved user may view
  RESTRICTED // entitlement required
}

enum CategoryKind {
  DAILY
  WEEKLY
  MONTHLY
  THEMATIC
}

// ─── Research taxonomy (derived from the real Vietcap corpus) ────────────────
// reportType = WHAT the note is; recommendation = the rating (orthogonal axis);
// tier = full report vs flash note; audience = client-facing vs internal-only.
enum ReportType {
  EARNINGS // KQKD — kết quả kinh doanh
  RESULT // KQ / KQLN — kết quả
  AGM // DHCD — đại hội cổ đông
  AGM_EXTRA // ĐHCĐ bất thường
  INVESTOR_MEETING // NDT — gặp gỡ nhà đầu tư
  COMPANY // BCCONGTY — báo cáo công ty
  COMPANY_VISIT // THAMDN — thăm doanh nghiệp
  INITIATION // BCLANDAU — báo cáo lần đầu
  LISTING // BCNIEMYET — niêm yết
  IPO
  BOND // PHTRAIPHIEU — phát hành trái phiếu
  DROP_COVERAGE // ngưng theo dõi
  VIEW // QUANDIEM — quan điểm
  PHTT // (cần Vietcap xác nhận nghĩa)
}

enum Recommendation {
  BUY // MUA
  HOLD // GIU / NAMGIU
  SELL // BAN
  REDUCE // GIAM
  ADD // THEM / THEMVAO
}

enum ReportTier {
  FULL // "Báo cáo"
  FLASH // "Nhận định nhanh"
}

enum Audience {
  CLIENT // visible to entitled clients via the publish pipeline
  INTERNAL // staff-only forever — never published to clients
}

enum AccessAction {
  VIEW
  DOWNLOAD
}

enum AuditAction {
  ACCOUNT_INVITE
  ACCOUNT_APPROVE
  ACCOUNT_REJECT
  ACCOUNT_SUSPEND
  ACCOUNT_REINSTATE
  ACCOUNT_LOCKED
  ACCOUNT_ROLE
  ENTITLEMENT_GRANT
  ENTITLEMENT_REVOKE
  REPORT_UPLOAD
  REPORT_SUBMIT
  REPORT_APPROVE
  REPORT_REJECT
  REPORT_PUBLISH
  REPORT_ARCHIVE
  REPORT_ACCESS
  REPORT_DELETE
  REPORT_TAG_ADD
  REPORT_TAG_REMOVE
  REPORT_INGEST
  REPORT_NOTIFY
  GROUP_CREATE
  GROUP_MEMBER_ADD
  GROUP_MEMBER_REMOVE
}

// ─── Identity / RBAC ─────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  name         String
  organization String?
  role         Role       @default(CLIENT)
  status       UserStatus @default(PENDING)
  // Bumped to invalidate outstanding JWTs immediately (suspend / force re-login).
  tokenVersion Int        @default(0)
  // Login throttle / lockout (blueprint §F3) — reset on success.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  // Email-verification gate: null until the user confirms via the emailed link.
  emailVerifiedAt  DateTime?
  // Watchlist notifications (F2): opt-out flag + one-click unsubscribe token.
  // Token is nullable so adding this UNIQUE column to existing rows is
  // db-push-safe (cuid() is app-side); it is lazily filled on first alert.
  watchlistEmails  Boolean   @default(true)
  unsubscribeToken String?   @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships     GroupMembership[]
  accessLogs      ReportAccessLog[]
  auditEvents     AuditLog[]        @relation("AuditActor")
  grantedEntitle  Entitlement[]     @relation("EntitlementGrantedBy")
  uploadedReports Report[]          @relation("ReportUploadedBy")
  uploadSessions  UploadSession[]
  watchlistItems  WatchlistItem[]
  notifications   ReportNotification[]

  // Auth.js adapter relations (kept for future OAuth/magic-link; JWT is primary).
  accounts Account[]
  sessions Session[]

  @@index([status])
  @@index([role])
}

// ─── Auth.js adapter models (standard) ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Client groups (tệp khách hàng) ──────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  members      GroupMembership[]
  entitlements Entitlement[]
}

model GroupMembership {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

// ─── Reports + categories + translations ─────────────────────────────────────

model Category {
  id        String       @id @default(cuid())
  kind      CategoryKind
  slug      String       @unique
  nameVi    String
  nameEn    String
  nameZh    String
  sortOrder Int          @default(0)

  reports      Report[]
  entitlements Entitlement[]
}

model Report {
  id          String       @id @default(cuid())
  slug        String       @unique
  categoryId  String
  status      ReportStatus @default(DRAFT)
  accessLevel AccessLevel  @default(RESTRICTED)
  publishedAt DateTime?
  // Storage pointer — NEVER exposed to the client; streamed via authed endpoint.
  fileKey     String?
  fileSize    Int?
  fileSha256  String?
  pageCount   Int?
  coverLabel  String? // short label shown on the document tile
  // ── Research taxonomy (orthogonal axes; nullable until tagged/ingested) ──
  reportType     ReportType?
  recommendation Recommendation?
  tier           ReportTier?
  audience       Audience        @default(CLIENT) // INTERNAL = staff-only forever
  reportDate     DateTime? // the report's own date (≠ publishedAt = when shown)
  // Extracted PDF plain text for full-text search — SERVER-ONLY, never sent to
  // the client (like fileKey). Populated at ingest/finalize.
  contentText    String?         @db.Text
  uploadedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category     Category           @relation(fields: [categoryId], references: [id])
  uploadedBy   User?              @relation("ReportUploadedBy", fields: [uploadedById], references: [id])
  translations ReportTranslation[]
  entitlements Entitlement[]
  accessLogs   ReportAccessLog[]
  symbols      ReportSymbol[]
  notifications ReportNotification[]

  // Keyset pagination index (publishedAt, id) — blueprint §F2.
  @@index([status, publishedAt, id])
  @@index([categoryId])
  @@index([reportType, publishedAt])
  @@index([recommendation])
  // Content dedup (Upload Flow). UNIQUE closes the app-level TOCTOU race —
  // Postgres allows multiple NULLs, so file-less drafts are unaffected; the
  // create path catches P2002 and returns the existing report.
  @@unique([fileSha256])
}

model ReportTranslation {
  id       String @id @default(cuid())
  reportId String
  locale   String // "vi" | "en" | "zh"
  title    String
  summary  String?
  author   String?
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, locale])
}

// ─── Entitlements (group → report OR group → category) ───────────────────────
// CHECK ("reportId" IS NOT NULL) <> ("categoryId" IS NOT NULL) is added via raw
// SQL in the migration (Prisma cannot express it) — blueprint §4.

model Entitlement {
  id          String   @id @default(cuid())
  groupId     String
  reportId    String?
  categoryId  String?
  grantedById String?
  createdAt   DateTime @default(now())

  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  report    Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  grantedBy User?     @relation("EntitlementGrantedBy", fields: [grantedById], references: [id])

  @@unique([groupId, reportId])
  @@unique([groupId, categoryId])
  @@index([groupId])
  @@index([reportId])
  @@index([categoryId])
}

// ─── Audit + access logs (append-only) ───────────────────────────────────────

model ReportAccessLog {
  id        String       @id @default(cuid())
  userId    String
  reportId  String
  action    AccessAction
  ip        String?
  userAgent String?
  createdAt DateTime     @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([userId, createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// ─── Resumable chunked upload ────────────────────────────────────────────────
// One session = one file uploaded in parts. Chunks are written to temp storage,
// reassembled + integrity-verified (size + SHA-256) at finalize, then a Report
// is created. Covers idempotency (uploadId), resume (received chunks), dedup
// (sha256), and completeness verification. Sweep expired OPEN sessions.
model UploadSession {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  totalSize   Int
  totalChunks Int
  chunkSize   Int
  sha256      String // client-declared full-file SHA-256 (hex) — VERIFIED at finalize
  status      String   @default("OPEN") // OPEN | FINALIZING | COMPLETED | ABORTED
  reportId    String? // set on completion so finalize is idempotent
  meta        Json // report metadata captured at init (titles, category, access, status)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks UploadChunk[]

  @@index([userId, status])
  @@index([sha256])
  @@index([expiresAt])
}

// One received chunk. The composite PK makes re-uploading a chunk idempotent
// (PUT same index twice = no-op), which is what makes retry/resume safe.
model UploadChunk {
  sessionId String
  index     Int
  size      Int
  createdAt DateTime @default(now())

  session UploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([sessionId, index])
}

// One-time, short-lived download grant (blueprint §F1) — the jti is recorded so
// a token can be used exactly once. Sweep expired rows periodically.
model DownloadToken {
  jti        String    @id
  userId     String
  reportId   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
}

// ─── Symbol axis (stock tickers) — the primary research navigation axis ──────
// Shared by full-text search (F1) and the watchlist (F2, future WatchlistItem).
model Symbol {
  id        String   @id @default(cuid())
  ticker    String   @unique // canonical UPPERCASE, e.g. "MWG", "HPG"
  exchange  String? // "HOSE" | "HNX" | "UPCOM"
  nameVi    String
  nameEn    String?
  nameZh    String?
  sector    String? // optional grouping (future "sector folders")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  reports  ReportSymbol[]
  watchers WatchlistItem[]
}

// Report ↔ Symbol (a report can cover several tickers; e.g. sector notes).
model ReportSymbol {
  reportId  String
  symbolId  String
  isPrimary Boolean @default(false) // the headline ticker for the report

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@id([reportId, symbolId])
  @@index([symbolId]) // ticker → reports lookup
}

// ─── Ingestion provenance (bulk import quality control) ──────────────────────
// One IngestBatch per run; files that can't be auto-classified become
// IngestIssue rows (a review queue) instead of silently corrupting the catalog.
model IngestBatch {
  id          String    @id @default(cuid())
  source      String // e.g. "vietcap-2026-06"
  startedById String?
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  filesSeen   Int       @default(0)
  imported    Int       @default(0)
  skipped     Int       @default(0)
  needsReview Int       @default(0)

  issues IngestIssue[]
}

model IngestIssue {
  id        String   @id @default(cuid())
  batchId   String
  filePath  String
  rawCode   String?
  reason    String // UNKNOWN_TYPE | NO_DATE | NO_TITLE | BAD_TICKER | DUPLICATE
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  batch IngestBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, resolved])
}

// ─── Watchlist (F2) — a client watches a Symbol; reports tagged with a watched
// symbol trigger a publish notification (the notify hook reuses authz.visibleWhere).
model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbolId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol Symbol @relation(fields: [symbolId], references: [id], onDelete: Cascade)

  @@unique([userId, symbolId])
  @@index([symbolId]) // symbol → watchers (fan-out on publish)
  @@index([userId])
}

// Idempotency ledger: one row per (report, user, channel) ever notified, so a
// republish / retry / re-run can NEVER double-send. The @@unique IS the guard.
model ReportNotification {
  id       String   @id @default(cuid())
  reportId String
  userId   String
  channel  String   @default("EMAIL") // EMAIL | INAPP (future)
  sentAt   DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reportId, userId, channel])
  @@index([userId])
}
